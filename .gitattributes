# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf
*.ps1 text eol=crlf

# XML and configuration files
*.xml text eol=lf
*.sumocfg text eol=lf
*.edg text eol=lf
*.nod text eol=lf
*.rou text eol=lf
*.tll text eol=lf

# Markdown and text
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
