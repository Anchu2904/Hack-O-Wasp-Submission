<?xml version="1.0" encoding="UTF-8"?>
<viewsettings>

    <scheme name="jaam_ctrl">
        <background backgroundColor="#0A0F1E" showGrid="0"/>

        <edges laneEdgeMode="0" laneShowBorders="1" showLinkDecals="1"
               widthExaggeration="2.0">
            <colorScheme name="uniform">
                <entry color="40,50,80"/>
            </colorScheme>
        </edges>

        <vehicles vehicleMode="0" vehicleQuality="2"
                  vehicleExaggeration="5.0" minVehicleSize="2.0"
                  showBlinker="1">
            <colorScheme name="given/assigned vehicle color">
                <entry color="0,200,255"/>
            </colorScheme>
        </vehicles>

        <junctions junctionMode="0" drawShape="1">
            <colorScheme name="uniform">
                <entry color="20,30,60"/>
            </colorScheme>
        </junctions>

        <legend showSizeLegend="0" showColorLegend="0"/>
    </scheme>

    <viewport x="500" y="0" zoom="200"/>
    <delay value="50"/>
    <breakpoints/>

</viewsettings>
